# Copy this file to .env and fill in your values.

# Google Gemini — free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — found in Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Super-admin credentials (optional — auto-generated if omitted, printed to logs once)
SUPER_ADMIN_USER=superadmin
SUPER_ADMIN_PASS=change_me_to_a_strong_password
